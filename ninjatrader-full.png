<script>
    let closeIcon = 'x-cross'
    let speedbumpUrl = function (url, target, triggerClass) {
        $('.' + triggerClass).modaal({
            type: 'confirm',
            start_open: true,
            confirm_button_text: 'Continue',
            confirm_cancel_button_text: `
                        <svg aria-hidden="true" focusable="false">
                            <use xlink:href="/assets/dist/images/svg-legend.svg#${closeIcon}"></use>
                        </svg>`,
            confirm_title: 'Attention!',
            confirm_content: 'You are now leaving a NinjaTrader website and will be redirected to a third-party site. Neither NinjaTrader nor its affiliated entities has endorsed or recommended for use any product, service, or statement offered or presented on the site you are about to visit. Third-party vendors and their websites, products, and services are independent and not affiliated with NinjaTrader or its affiliated entities.<br /><br />By clicking the button below, I confirm to have read and understood the statement above.',
            confirm_callback: function () {
                // Always open in new tab
                window.open(url);

                /*
                if (target == '_blank') {
                    window.open(url);
                } else {
                    window.location.href = url;
                }*/
            },
            confirm_cancel_callback: function () {
                $('.' + triggerClass).modaal('close');
            }
        });
    }

    const blacklistedDomains = JSON.parse('["ninjatraderecosystem.com","youtube.com","anthonycrudele.com","daytradetowin.com","thelabtrading.com","livestreamtrading.com","moneylinetradingco.com","thepaxgroup.org","stratalerts.ai","x.com","vipertradingsystems.com","crowdedmarketsreport.com","idta.com.au","jtrader.co","microefutures.wordpress.com","crowdedmarketreport.com","try.takeprofittrader.com","alpha-futures.com","blusky.pro","emergeprofit.com","elitetraderfunding.com","fundedfuturesfamily.com","checkout.fundingfutures.com","app.fundingticks.com","tradefundrr.com","fxifyfutures.com","ninjatrader.thelegendstrading.com","lifeuptrading.com","myfundedfutures.com","purdia.com","client-area.thetradingpit.com","tickticktrader.com","tradeday.com","fundingtrading.com","tradeify.co","apextraderfunding.com","fundednext.com","goatfundedfutures.com","thelegendstrading.com","lucidtrading.com","takeprofittrader.com","fundingfutures.com","thetradingpit.com","app.fxifyfutures.com","facebook.com","x.com","linkedin.com","instagram.com"]');
    const anchorTags = document.getElementsByTagName('a');
    var count = 0;

    for (const element of anchorTags) {
        const domain = element.host.replace('www.', '').toLowerCase();

        if ((blacklistedDomains.includes(domain) || element.classList.contains('js-globalspeedbump')) && !element.classList.contains('js-noglobalspeedbump')) {
            var triggerClass = 'speedbump-trigger-' + count;

            element.classList.add(triggerClass);
            element.href = 'javascript: speedbumpUrl("' + element.href + '","' + element.target + '","' + triggerClass + '");';
            element.target = '_self';
            count++;
        }
    }
</script>

    <script src="/assets/dist/js/all.min.js?v=sXE0-SPGp_Nwvi3nE1MRKW5k8uJH1QSHLzs4SSvv3kU"></script>

     
    
</body>
</html>